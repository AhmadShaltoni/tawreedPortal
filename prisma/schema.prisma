// Prisma schema for Tawreed B2B Grocery Marketplace
// Platform: توريد - Curated Marketplace for Grocery Stores in Jordan

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User roles in the platform
enum UserRole {
  BUYER     // Grocery store owners (mobile app)
  SUPPLIER  // Wholesale distributors (managed by admin)
  ADMIN     // Platform administrators (dashboard)
}

// Status of a purchase request (RFQ) - Legacy
enum RequestStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  CANCELLED
  EXPIRED
}

// Status of a supplier's offer - Legacy
enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

// Status of an order
enum OrderStatus {
  PENDING       // Order placed, awaiting admin confirmation
  CONFIRMED     // Admin confirmed the order
  PROCESSING    // Order is being prepared
  SHIPPED       // Order is in transit / out for delivery
  DELIVERED     // Order delivered to buyer
  CANCELLED     // Order cancelled
}

// Notification types
enum NotificationType {
  NEW_REQUEST     // Legacy
  NEW_OFFER       // Legacy
  OFFER_ACCEPTED  // Legacy
  OFFER_REJECTED  // Legacy
  ORDER_UPDATE    // Order status changed
  NEW_ORDER       // New order placed (for admin)
  ORDER_STATUS_CHANGE // Order status changed (for buyer)
  SYSTEM          // System notifications
}

// Product categories - Legacy enum (kept for old Request model)
enum ProductCategory {
  SUGAR
  RICE
  CANDY_SNACKS
  DAIRY
  BEVERAGES
  CANNED_GOODS
  COOKING_OIL
  FLOUR_GRAINS
  SPICES
  CLEANING
  PERSONAL_CARE
  OTHER
}

// Unit of measurement
enum Unit {
  KG        // Kilogram
  GRAM      // Gram
  LITER     // Liter
  PIECE     // Individual piece
  PACK      // Package
  BOX       // Box
  CARTON    // Carton
  DOZEN     // 12 pieces
  PALLET    // Pallet
}

// Device platform for push notifications
enum Platform {
  IOS
  ANDROID
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id            String    @id @default(cuid())
  phone         String    @unique  // رقم الهاتف كمعرّف فريد (07xxxxxxxx)
  email         String?   @unique  // اختياري
  passwordHash  String
  username      String    // اسم المستخدم (بدلاً من name)
  role          UserRole
  
  // Business details
  storeName     String?   // اسم البقالة/المتجر (بدلاً من businessName)
  businessAddress String?
  city          String?
  
  // Structured location
  cityId        String?
  cityRef       City?     @relation(fields: [cityId], references: [id])
  areaId        String?
  areaRef       Area?     @relation(fields: [areaId], references: [id])
  latitude      Float?
  longitude     Float?
  address       String?
  
  // For suppliers: areas they can deliver to
  deliveryAreas String[]
  
  // Verification
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations - Legacy RFQ
  requests      Request[]       @relation("BuyerRequests")
  offers        Offer[]         @relation("SupplierOffers")
  
  // Relations - New e-commerce
  buyerOrders   Order[]         @relation("BuyerOrders")
  supplierOrders Order[]        @relation("SupplierOrders")
  notifications Notification[]
  cartItems     CartItem[]
  deviceTokens  DeviceToken[]   // Multiple devices per user
  discountCodeUsages DiscountCodeUsage[]
  
  @@index([role])
  @@index([city])
  @@index([cityId])
  @@index([areaId])
}

// Purchase Request (RFQ - Request for Quotation)
model Request {
  id            String        @id @default(cuid())
  
  // Request details
  title         String
  description   String?
  category      ProductCategory
  
  // Product specifications
  productName   String
  quantity      Float
  unit          Unit
  
  // Optional specifications
  brand         String?       // Preferred brand (if any)
  specifications String?      // Additional specs (e.g., "organic", "imported")
  
  // Delivery requirements
  deliveryCity  String
  deliveryAddress String?
  deliveryDeadline DateTime?
  
  // Budget
  maxBudget     Float?        // Maximum budget (optional)
  
  // Status & timing
  status        RequestStatus @default(OPEN)
  expiresAt     DateTime      // When the request stops accepting offers
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  buyerId       String
  buyer         User          @relation("BuyerRequests", fields: [buyerId], references: [id], onDelete: Cascade)
  offers        Offer[]
  order         Order?
  
  @@index([status])
  @@index([category])
  @@index([deliveryCity])
  @@index([buyerId])
  @@index([createdAt])
}

// Supplier's Offer on a Request
model Offer {
  id            String      @id @default(cuid())
  
  // Pricing
  pricePerUnit  Float
  totalPrice    Float
  quantity      Float       // Quantity supplier can provide
  unit          Unit
  
  // Delivery terms
  deliveryDays  Int         // Days needed for delivery
  deliveryNotes String?
  
  // Offer details
  notes         String?     // Additional notes from supplier
  validUntil    DateTime    // Offer validity period
  
  // Status
  status        OfferStatus @default(PENDING)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relations
  requestId     String
  request       Request     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  supplierId    String
  supplier      User        @relation("SupplierOffers", fields: [supplierId], references: [id], onDelete: Cascade)
  
  order         Order?
  
  @@unique([requestId, supplierId]) // One offer per supplier per request
  @@index([status])
  @@index([supplierId])
  @@index([requestId])
}

// Order (created when an offer is accepted - Legacy, or from cart - New)
model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique @default(cuid())
  
  // Order total
  totalPrice    Float
  
  // Delivery
  deliveryAddress String
  deliveryCity    String
  expectedDelivery DateTime?
  actualDelivery   DateTime?
  
  // Status
  status        OrderStatus @default(PENDING)
  statusHistory Json        @default("[]") // Array of {status, timestamp, note}
  
  // Notes
  buyerNotes    String?
  adminNotes    String?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relations - Buyer
  buyerId       String
  buyer         User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  
  // Relations - Supplier (admin assigns, optional)
  supplierId    String?
  supplier      User?       @relation("SupplierOrders", fields: [supplierId], references: [id])
  
  // Relations - Order items
  items         OrderItem[]
  
  // Legacy relations (nullable for new orders)
  requestId     String?     @unique
  request       Request?    @relation(fields: [requestId], references: [id])
  offerId       String?     @unique
  offer         Offer?      @relation(fields: [offerId], references: [id])
  
  @@index([status])
  @@index([buyerId])
  @@index([supplierId])
  @@index([createdAt])
}

// Order item (snapshot of product at time of order)
model OrderItem {
  id            String   @id @default(cuid())
  
  // Product snapshot
  productId     String?  // Optional for RFQ-based orders
  productName   String
  productNameEn String?
  productImage  String?
  
  // Variant snapshot
  variantSize   String?    // e.g., "2 كيلو"
  variantSizeEn String?    // e.g., "2kg"
  
  // Unit snapshot (captures which unit was selected at order time)
  unitLabel     String?    // e.g., "كرتونة (36 قطعة)"
  unitLabelEn   String?    // e.g., "Carton (36 pieces)"
  piecesPerUnit Int       @default(1) // How many pieces in the selected unit
  
  // Pricing
  quantity      Int
  unit          Unit
  pricePerUnit  Float
  totalPrice    Float
  
  // Relations
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product? @relation(fields: [productId], references: [id])
  
  @@index([orderId])
  @@index([productId])
}

// ============================================
// E-COMMERCE MODELS
// ============================================

// Product category (flexible, admin-managed, hierarchical)
model Category {
  id          String    @id @default(cuid())
  name        String    // Arabic name
  nameEn      String?   // English name
  slug        String    @unique // URL-safe identifier
  image       String?   // Category image path
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  
  // Hierarchy fields
  parentId    String?   // Self-referencing FK for nested categories
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  depth       Int       @default(0)  // Cached depth level (root=0)
  path        String    @default("") // Materialized path for efficient descendant queries
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  products    Product[]
  
  @@index([sortOrder])
  @@index([isActive])
  @@index([parentId])
  @@index([path])
}

// Supplier (managed by admin, provides products)
model Supplier {
  id          String    @id @default(cuid())
  name        String    // Arabic name
  nameEn      String?   // English name
  phone       String?
  email       String?
  address     String?
  city        String?
  isDefault   Boolean   @default(false) // Default supplier for new products
  isActive    Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  products    Product[]
  
  @@index([isActive])
  @@index([isDefault])
}

// Product in the catalog
model Product {
  id              String    @id @default(cuid())
  
  // Basic info
  name            String    // Arabic name
  nameEn          String?   // English name
  description     String?   // Arabic description
  descriptionEn   String?   // English description
  
  // Media
  image           String?   // Main product image path
  images          String[]  // Additional images
  
  // Classification
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])
  
  // Supplier
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  
  // Status
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  variants        ProductVariant[]  // Multiple size variants (e.g., 2kg, 4kg)
  orderItems      OrderItem[]
  
  @@index([categoryId])
  @@index([supplierId])
  @@index([isActive])
  @@index([sortOrder])
}

// Product size variant (e.g., 2kg, 4kg of the same product)
model ProductVariant {
  id              String    @id @default(cuid())
  
  // Size info
  size            String    // Arabic size label: "2 كيلو", "4 كيلو"
  sizeEn          String?   // English size label: "2kg", "4kg"
  
  // Inventory (per variant)
  sku             String?   @unique
  barcode         String?
  stock           Int       @default(0)
  minOrderQuantity Int      @default(1)
  
  // Status
  isDefault       Boolean   @default(false) // Default variant shown in product card
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  units           ProductUnit[]  // Selling units for this variant (piece, dozen, carton...)
  cartItems       CartItem[]
  
  @@index([productId])
}

// Product selling unit (e.g., piece, dozen, carton with different prices)
model ProductUnit {
  id              String    @id @default(cuid())
  
  unit            Unit      // PIECE, DOZEN, CARTON, BOX, etc.
  label           String    // Arabic label: "قطعة", "دزينة", "كرتونة"
  labelEn         String?   // English label: "Piece", "Dozen", "Carton"
  piecesPerUnit   Int       @default(1)  // 1 for piece, 12 for dozen, 36 for carton
  price           Float     // Price for this unit (JOD)
  wholesalePrice  Float?    // Wholesale/cost price for profit calculation (JOD)
  compareAtPrice  Float?    // Original price before discount for this unit
  isDefault       Boolean   @default(false) // Default unit shown in product card
  sortOrder       Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  cartItems       CartItem[]
  
  @@unique([variantId, unit]) // No duplicate unit per variant
  @@index([variantId])
}

// Shopping cart item (server-side cart for mobile app)
model CartItem {
  id          String   @id @default(cuid())
  quantity    Int      @default(1)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  buyerId     String
  buyer       User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  
  // Variant (required - specifies which size variant)
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  
  // Selected unit (optional - if null, uses variant default unit/price)
  productUnitId String?
  productUnit   ProductUnit? @relation(fields: [productUnitId], references: [id])
  
  @@unique([buyerId, variantId, productUnitId]) // One cart entry per variant+unit per buyer
  @@index([buyerId])
}

// Notifications
model Notification {
  id            String           @id @default(cuid())
  type          NotificationType
  title         String
  message       String
  
  // Link to related entity
  linkUrl       String?
  imageUrl      String?          // Optional image for push notifications
  data          Json?            // Custom payload data for deep linking
  
  // Push status
  isSent        Boolean          @default(false)  // Whether push was actually sent
  isGlobal      Boolean          @default(false)  // Broadcast to all users
  
  // Read status
  isRead        Boolean          @default(false)
  
  createdAt     DateTime         @default(now())
  
  // Relations
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isRead])
  @@index([createdAt])
  @@index([isSent])
}

// Notices/Announcements - Rotating banner on home screen
model Notice {
  id              String    @id @default(cuid())
  
  // Content
  text            String    @db.VarChar(255)  // Max 255 chars
  
  // Styling
  backgroundColor String    @default("#f97316")  // Hex color format (#RRGGBB)
  textColor       String    @default("#FFFFFF")  // Hex color format (#RRGGBB)
  
  // Display settings
  isMobileOnly    Boolean   @default(true)   // Show only in mobile app, not on website
  
  // Status (soft delete)
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([isActive])
  @@index([isMobileOnly])
  @@index([createdAt])
}

// Device tokens for push notifications
model DeviceToken {
  id            String    @id @default(cuid())
  token         String    @unique  // FCM or Expo token
  platform      Platform            // IOS or ANDROID
  
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isActive])
}

// ============================================
// LOCATION MODELS
// ============================================

// Jordan cities
model City {
  id        String   @id @default(cuid())
  name      String   // Arabic name
  nameEn    String   // English name
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  areas     Area[]
  users     User[]

  @@index([sortOrder])
}

// Areas within a city
model Area {
  id        String   @id @default(cuid())
  name      String   // Arabic name
  nameEn    String   // English name
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cityId    String
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  users     User[]

  @@index([cityId])
  @@index([sortOrder])
}

// ============================================
// DISCOUNT CODE (COUPON) MODELS
// ============================================

// Discount codes managed by admin
model DiscountCode {
  id              String    @id @default(cuid())
  
  // Core fields
  code            String    @unique  // Stored uppercase (e.g. ISTKLAL2026, SBA)
  discountPercent Float              // Percentage (e.g. 15 = 15%)
  
  // Usage rules
  isSingleUse     Boolean   @default(false)  // Each user can use only once
  maxUsage        Int?               // Max total uses across all users (null = unlimited)
  minOrderAmount  Float?             // Min order total for code to be valid (JOD)
  
  // Date range
  startDate       DateTime?          // When code becomes active (null = immediately)
  endDate         DateTime?          // When code expires (null = no expiry)
  
  // Status
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  usages          DiscountCodeUsage[]
  
  @@index([code])
  @@index([isActive])
}

// Tracks each use of a discount code
model DiscountCodeUsage {
  id              String    @id @default(cuid())
  
  discountAmount  Float              // Actual JOD saved
  orderTotal      Float              // Order total before discount
  
  createdAt       DateTime  @default(now())
  
  // Relations
  discountCodeId  String
  discountCode    DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  orderId         String?            // Linked after order is placed
  
  @@index([discountCodeId])
  @@index([userId])
  @@index([discountCodeId, userId])
}
